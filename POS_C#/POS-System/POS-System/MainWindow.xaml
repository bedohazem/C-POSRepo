<Window x:Class="POS_System.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="POS System" Height="650" Width="1050"
        WindowStartupLocation="CenterScreen"
        Background="#0B1220"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        MinWidth="900" MinHeight="600"
        WindowState="Maximized">

    <!-- ✅ استخدم Styles.xaml (Tokens) -->
    <!-- مفيش Resources محلية هنا إلا لو محتاج -->
    <Grid>

        <!-- ✅ Columns -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ✅ Rows -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===================== -->
        <!-- ===== TOP BAR ======= -->
        <!-- ===================== -->
        <Border Grid.ColumnSpan="2"
                Background="#0B1220"
                Padding="14"
                BorderBrush="#1F2937"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[App_Title]}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#E5E7EB"/>
                    <TextBlock x:Name="UserLabel"
                               Foreground="#93C5FD"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <!-- مساحة يمين لو هتزود search/clock بعدين -->
                <Border Grid.Column="1"
                        Background="#111827"
                        BorderBrush="#1F2937"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="10,8"
                        VerticalAlignment="Center"
                        Margin="10,0,0,0">
                    <TextBlock Text="POS"
                               Foreground="#E5E7EB"
                               FontWeight="Bold"
                               Opacity="0.9"/>
                </Border>
            </Grid>
        </Border>

        <!-- ===================== -->
        <!-- ===== SIDEBAR ======= -->
        <!-- ===================== -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="#111827"
                CornerRadius="20"
                Margin="12"
                ClipToBounds="True"
                BorderBrush="#1F2937"
                BorderThickness="1">

            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Margin="6,6,6,10">
                    <TextBlock Text="POS System"
                               Foreground="#E5E7EB"
                               FontSize="20"
                               FontWeight="Bold"/>
                    <TextBlock Text="القائمة"
                               Foreground="#9CA3AF"
                               FontSize="12"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Menu -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="True"
                              Padding="0,2,0,2">

                    <!-- ✅ ستايل NavList و NavListItem جاية من Styles.xaml -->
                    <ListBox x:Name="NavList"
                             SelectionChanged="NavList_SelectionChanged"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                        <!-- item template موحد + Tag زي ما هو -->
                        <ListBoxItem Tag="sales">
                            <DockPanel LastChildFill="True">
                                <TextBlock Text="💳" FontSize="14" Margin="0,0,10,0" Opacity="0.9"/>
                                <TextBlock Text="المبيعات"/>
                            </DockPanel>
                        </ListBoxItem>

                        <ListBoxItem Tag="sales-history">
                            <DockPanel LastChildFill="True">
                                <TextBlock Text="🧾" FontSize="14" Margin="0,0,10,0" Opacity="0.9"/>
                                <TextBlock Text="سجل المبيعات"/>
                            </DockPanel>
                        </ListBoxItem>

                        <ListBoxItem Tag="products">
                            <DockPanel LastChildFill="True">
                                <TextBlock Text="🧾" FontSize="14" Margin="0,0,10,0" Opacity="0.9"/>
                                <TextBlock Text="المنتجات"/>
                            </DockPanel>
                        </ListBoxItem>

                        <ListBoxItem Tag="warehouse">
                            <DockPanel LastChildFill="True">
                                <TextBlock Text="📦" FontSize="14" Margin="0,0,10,0" Opacity="0.9"/>
                                <TextBlock Text="المخزن"/>
                            </DockPanel>
                        </ListBoxItem>

                        <ListBoxItem Tag="returns">
                            <DockPanel LastChildFill="True">
                                <TextBlock Text="↩" FontSize="14" Margin="0,0,10,0" Opacity="0.9"/>
                                <TextBlock Text="المرتجعات"/>
                            </DockPanel>
                        </ListBoxItem>

                        <ListBoxItem Tag="reports">
                            <DockPanel LastChildFill="True">
                                <TextBlock Text="📈" FontSize="14" Margin="0,0,10,0" Opacity="0.9"/>
                                <TextBlock Text="التقارير"/>
                            </DockPanel>
                        </ListBoxItem>

                        <ListBoxItem Tag="customers">
                            <DockPanel LastChildFill="True">
                                <TextBlock Text="👤" FontSize="14" Margin="0,0,10,0" Opacity="0.9"/>
                                <TextBlock Text="العملاء"/>
                            </DockPanel>
                        </ListBoxItem>

                        <ListBoxItem Tag="users">
                            <DockPanel LastChildFill="True">
                                <TextBlock Text="👥" FontSize="14" Margin="0,0,10,0" Opacity="0.9"/>
                                <TextBlock Text="المستخدمين"/>
                            </DockPanel>
                        </ListBoxItem>

                        <ListBoxItem Tag="branches">
                            <DockPanel LastChildFill="True">
                                <TextBlock Text="🏬" FontSize="14" Margin="0,0,10,0" Opacity="0.9"/>
                                <TextBlock Text="الفروع"/>
                            </DockPanel>
                        </ListBoxItem>

                        <ListBoxItem Tag="audit">
                            <DockPanel LastChildFill="True">
                                <TextBlock Text="🧠" FontSize="14" Margin="0,0,10,0" Opacity="0.9"/>
                                <TextBlock Text="سجل العمليات"/>
                            </DockPanel>
                        </ListBoxItem>

                        <ListBoxItem Tag="settings">
                            <DockPanel LastChildFill="True">
                                <TextBlock Text="⚙" FontSize="14" Margin="0,0,10,0" Opacity="0.9"/>
                                <TextBlock Text="الإعدادات"/>
                            </DockPanel>
                        </ListBoxItem>

                    </ListBox>
                </ScrollViewer>

                <!-- Footer -->
                <StackPanel Grid.Row="2" Margin="6,10,6,6">
                    <Border Height="1" Background="#1F2937" Opacity="0.9" Margin="0,6,0,10"/>

                    <Button Content="قفل"
                            Click="Lock_Click"
                            Style="{StaticResource SidebarGhostButtonStyle}"
                            Margin="0,0,0,8"/>

                    <Button Content="تسجيل الخروج"
                            Click="Logout_Click"
                            Style="{StaticResource SidebarDangerGhostButtonStyle}"/>
                </StackPanel>

            </Grid>
        </Border>

        <!-- ===================== -->
        <!-- ===== CONTENT ======= -->
        <!-- ===================== -->
        <Border Grid.Row="1" Grid.Column="1"
                Background="#0B1220"
                CornerRadius="16"
                Margin="0,14,14,14"
                Padding="12"
                BorderBrush="#1F2937"
                BorderThickness="1">
            <Frame x:Name="RootFrame"
                   NavigationUIVisibility="Hidden"/>
        </Border>

        <!-- ===================== -->
        <!-- == AUTH OVERLAY MODAL -->
        <!-- ===================== -->
        <Grid x:Name="AuthOverlay"
              Grid.Row="0"
              Grid.Column="0"
              Grid.RowSpan="2"
              Grid.ColumnSpan="2"
              Visibility="Collapsed"
              Background="#E6000000"
              Panel.ZIndex="9999"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              IsHitTestVisible="True">

            <Border Width="520"
                    CornerRadius="22"
                    Background="#111827"
                    BorderBrush="#1F2937"
                    BorderThickness="1"
                    Padding="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="26" ShadowDepth="0" Opacity="0.35"/>
                </Border.Effect>

                <Frame x:Name="AuthFrame"
                       NavigationUIVisibility="Hidden"
                       Background="#111827"/>
            </Border>
        </Grid>

    </Grid>
</Window>