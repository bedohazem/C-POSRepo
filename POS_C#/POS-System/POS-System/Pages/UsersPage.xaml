<Page x:Class="POS_System.UsersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource Bg}"
      Foreground="{StaticResource TextBrush}" Opacity="0">


    
    <Page.RenderTransform>
        <TranslateTransform Y="8"/>
    </Page.RenderTransform>

    <Page.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.18"/>
                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)"
                                     From="8" To="0" Duration="0:0:0.18"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Page.Triggers>

<Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="إدارة المستخدمين" FontSize="20" FontWeight="Bold"/>
                    <TextBlock Text="إضافة / تعديل / تعطيل المستخدمين وتحديد الصلاحيات والفروع" Opacity="0.75" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBox x:Name="SearchBox" Width="260" Margin="0,0,10,0"
                             Style="{StaticResource DarkTextBoxStyle}"
                             TextChanged="SearchBox_TextChanged"
                             ToolTip="بحث بالاسم / الدور / الفرع"/>
                    <Button Content="Add User" Style="{StaticResource PrimaryButtonStyle}" Click="Add_Click"/>
                    <Button Content="Refresh" Margin="10,0,0,0" Style="{StaticResource DarkButtonStyle}" Click="Refresh_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- List -->
        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
            <DockPanel>
                <ListView x:Name="UsersList" 
                          Style="{StaticResource DarkListViewStyle}" 
                          ItemContainerStyle="{StaticResource DarkGridViewItemStyle}"
                          SelectionMode="Single">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Id" DisplayMemberBinding="{Binding Id}" Width="60"/>
                            <GridViewColumn Header="Username" DisplayMemberBinding="{Binding Username}" Width="220"/>
                            <GridViewColumn Header="Role" DisplayMemberBinding="{Binding RoleName}" Width="160"/>
                            <GridViewColumn Header="Branch" DisplayMemberBinding="{Binding BranchName}" Width="220"/>
                            <GridViewColumn Header="Active" DisplayMemberBinding="{Binding IsActive}" Width="80"/>
                        </GridView>
                    </ListView.View>
                </ListView>

                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,12,0,0">
                    <Button Content="Edit" Width="110" Style="{StaticResource DarkButtonStyle}" Click="Edit_Click"/>
                    <Button Content="Reset PW" Width="120" Margin="10,0,0,0" Style="{StaticResource DarkButtonStyle}" Click="ResetPw_Click"/>
                    <Button Content="Toggle" Width="110" Margin="10,0,0,0" Style="{StaticResource DarkButtonStyle}" Click="ToggleActive_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ========= Overlay: User Editor ========= -->
        <Grid x:Name="EditorOverlay" Visibility="Collapsed"
              Grid.RowSpan="2" Background="#99000000">
            <Border Width="680" Padding="16" CornerRadius="18"
                    BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1"
                    Background="{StaticResource Surface}"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>

                    <TextBlock x:Name="EditorTitle" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Username" Opacity="0.8" Margin="0,0,0,6"/>
                            <TextBox x:Name="UserBox" Style="{StaticResource DarkTextBoxStyle}"/>

                            <TextBlock Text="Role" Opacity="0.8" Margin="0,12,0,6"/>
                            <ComboBox x:Name="RoleBox" Height="34"/>

                            <CheckBox x:Name="ActiveBox" Content="Active" IsChecked="True" Margin="0,12,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Password" Opacity="0.8" Margin="0,0,0,6"/>
                            <PasswordBox x:Name="PassBox" Height="34" Padding="10,6"/>

                            <TextBlock x:Name="HintText" Opacity="0.7" Margin="0,8,0,10"/>

                            <TextBlock Text="Branches" Opacity="0.8" Margin="0,8,0,6"/>
                            <Border BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" CornerRadius="10" Background="{StaticResource Bg}">
                                <ScrollViewer Height="150">
                                    <ItemsControl x:Name="BranchesList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Content="{Binding Name}"
                                                          IsChecked="{Binding IsSelected}"
                                                          Margin="10,6"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <UniformGrid Columns="2" Margin="0,16,0,0">
                        <Button Content="Save" Height="40" Margin="4" Style="{StaticResource PrimaryButtonStyle}" Click="Save_Click"/>
                        <Button Content="Cancel" Height="40" Margin="4" Style="{StaticResource DarkButtonStyle}" Click="Cancel_Click"/>
                    </UniformGrid>

                </StackPanel>
            </Border>
        </Grid>

        <!-- ========= Overlay: Reset Password ========= -->
        <Grid x:Name="ResetOverlay" Visibility="Collapsed"
              Grid.RowSpan="2" Background="#99000000">
            <Border Width="520" Padding="16" CornerRadius="18"
                    BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1"
                    Background="{StaticResource Surface}"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Reset Password" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>
                    <TextBlock x:Name="ResetUserInfo" Opacity="0.8" Margin="0,0,0,10"/>

                    <TextBlock Text="New Password" Opacity="0.8" Margin="0,0,0,6"/>
                    <PasswordBox x:Name="ResetPassBox" Height="34" Padding="10,6"/>

                    <UniformGrid Columns="2" Margin="0,16,0,0">
                        <Button Content="Save" Height="40" Margin="4" Style="{StaticResource PrimaryButtonStyle}" Click="ResetSave_Click"/>
                        <Button Content="Cancel" Height="40" Margin="4" Style="{StaticResource DarkButtonStyle}" Click="ResetCancel_Click"/>
                    </UniformGrid>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</Page>