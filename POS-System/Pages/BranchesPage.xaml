<Page x:Class="POS_System.BranchesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource Bg}"
      Foreground="{StaticResource TextBrush}" Opacity="0">




    <Page.RenderTransform>
        <TranslateTransform Y="8"/>
    </Page.RenderTransform>

    <Page.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.18"/>
                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)"
                                     From="8" To="0" Duration="0:0:0.18"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Page.Triggers>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="إدارة الفروع" FontSize="20" FontWeight="Bold"/>
                    <TextBlock Text="إضافة / تعديل / تعطيل الفروع" Opacity="0.75" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBox x:Name="SearchBox" Width="260" Margin="0,0,10,0"
                             Style="{StaticResource DarkTextBoxStyle}"
                             TextChanged="SearchBox_TextChanged"
                             ToolTip="بحث بالاسم"/>
                    <Button Content="Add Branch" Style="{StaticResource PrimaryButtonStyle}" Click="Add_Click"/>
                    <Button Content="Refresh" Margin="10,0,0,0" Style="{StaticResource DarkButtonStyle}" Click="Refresh_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- List -->
        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
            <DockPanel>
                <ListView x:Name="BranchesList" 
                          Style="{StaticResource DarkListViewStyle}" 
                          ItemContainerStyle="{StaticResource DarkGridViewItemStyle}"
                          SelectionMode="Single">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Id" DisplayMemberBinding="{Binding Id}" Width="70"/>
                            <GridViewColumn Header="Branch Name" DisplayMemberBinding="{Binding Name}" Width="360"/>
                            <GridViewColumn Header="Active" DisplayMemberBinding="{Binding IsActive}" Width="90"/>
                        </GridView>
                    </ListView.View>
                </ListView>

                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,12,0,0">
                    <Button Content="Edit" Width="110" Style="{StaticResource DarkButtonStyle}" Click="Edit_Click"/>
                    <Button Content="Toggle" Width="110" Margin="10,0,0,0" Style="{StaticResource DarkButtonStyle}" Click="Toggle_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Overlay Editor -->
        <Grid x:Name="EditorOverlay" Visibility="Collapsed"
              Grid.RowSpan="2" Background="#99000000">
            <Border Width="520" Padding="16" CornerRadius="18"
                    BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1"
                    Background="{StaticResource Surface}"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>

                    <TextBlock x:Name="EditorTitle" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>

                    <TextBlock Text="Branch Name" Opacity="0.8" Margin="0,0,0,6"/>
                    <TextBox x:Name="NameBox" Style="{StaticResource DarkTextBoxStyle}"/>

                    <CheckBox x:Name="ActiveBox" Content="Active" IsChecked="True" Margin="0,12,0,0"/>

                    <UniformGrid Columns="2" Margin="0,16,0,0">
                        <Button Content="Save" Height="40" Margin="4" Style="{StaticResource PrimaryButtonStyle}" Click="EditorSave_Click"/>
                        <Button Content="Cancel" Height="40" Margin="4" Style="{StaticResource DarkButtonStyle}" Click="EditorCancel_Click"/>
                    </UniformGrid>

                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</Page>