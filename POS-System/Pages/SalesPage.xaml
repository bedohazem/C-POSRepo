<Page x:Class="POS_System.SalesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource Bg}"
      Foreground="{StaticResource TextBrush}"
      FlowDirection="RightToLeft"
      PreviewKeyDown="Page_PreviewKeyDown"
      Opacity="0"
      Loaded="Page_Loaded">

    <Page.Resources>
        <Style x:Key="SalesSectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Opacity" Value="0.72"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="SalesMiniStatStyle" TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="CornerRadius" Value="14"/>
        </Style>

        <Style x:Key="SalesGhostSmallButtonStyle" TargetType="Button" BasedOn="{StaticResource DarkButtonStyle}">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="42"/>
            <Setter Property="Padding" Value="12,0"/>
        </Style>
    </Page.Resources>

    <Page.RenderTransform>
        <TranslateTransform Y="8"/>
    </Page.RenderTransform>

    <Page.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.18"/>
                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)"
                                     From="8" To="0" Duration="0:0:0.18"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Page.Triggers>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal">
                <Button Content="+ فاتورة جديدة"
                        MinWidth="160"
                        Height="44"
                        Padding="18,0"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="NewInvoice_Click"/>

                <Button Content="تركيز الباركود  F6"
                        Margin="10,0,0,0"
                        MinWidth="150"
                        Height="44"
                        Style="{StaticResource DarkButtonStyle}"
                        Click="FocusBarcode_Click"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Border Style="{StaticResource SalesMiniStatStyle}" Margin="0,0,10,0" MinWidth="150">
                    <StackPanel>
                        <TextBlock Text="المستخدم" Opacity="0.7" FontSize="12"/>
                        <TextBlock x:Name="CashierText" FontWeight="SemiBold" FontSize="15"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SalesMiniStatStyle}" MinWidth="170">
                    <StackPanel>
                        <TextBlock Text="الفرع" Opacity="0.7" FontSize="12"/>
                        <TextBlock x:Name="BranchText" FontWeight="SemiBold" FontSize="15"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- Invoice Tabs -->
        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Padding="10" Margin="0,0,0,12">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <StackPanel x:Name="InvoiceTabsPanel" Orientation="Horizontal"/>
            </ScrollViewer>
        </Border>

        <!-- Workflow / Header Form -->
        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}" Padding="14" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- first row -->
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.2*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="اختيار صنف" Style="{StaticResource SalesSectionTitleStyle}"/>
                        <ComboBox x:Name="ProductPickerCombo"
                                  Height="42"
                                  IsEditable="True"
                                  IsTextSearchEnabled="False"
                                  StaysOpenOnEdit="True"
                                  KeyUp="ProductPickerCombo_KeyUp"
                                  SelectionChanged="ProductPickerCombo_SelectionChanged"
                                  PreviewMouseLeftButtonDown="ProductPickerCombo_PreviewMouseLeftButtonDown"
                                  GotKeyboardFocus="ProductPickerCombo_GotKeyboardFocus"
                                  Style="{StaticResource DiscountComboStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                        <TextBlock Text="اختيار عميل" Style="{StaticResource SalesSectionTitleStyle}"/>
                        <ComboBox x:Name="CustomerPickerCombo"
                                  Height="42"
                                  IsEditable="True"
                                  IsTextSearchEnabled="False"
                                  StaysOpenOnEdit="True"
                                  SelectionChanged="CustomerPickerCombo_SelectionChanged"
                                  KeyUp="CustomerPickerCombo_KeyUp"
                                  Style="{StaticResource DiscountComboStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,19,10,0">
                        <Button Width="42"
                                Height="42"
                                Content="+"
                                FontSize="18"
                                FontWeight="Bold"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="OpenAddCustomerOverlay_Click"/>
                    </StackPanel>


                </Grid>

                <!-- second row -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.3*"/>
                        <ColumnDefinition Width="1.6*"/>
                        <ColumnDefinition Width="1.55*"/>
                        <ColumnDefinition Width="1.65*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="باركود / بحث سريع" Style="{StaticResource SalesSectionTitleStyle}"/>
                        <Border Background="{StaticResource Bg}"
                                BorderBrush="{StaticResource BorderBrushDark}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="10,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="⌕"
                                           FontSize="18"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"
                                           Opacity="0.75"/>

                                <TextBox x:Name="BarcodeBox"
                                         Grid.Column="1"
                                         Height="42"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         FontSize="15"
                                         VerticalContentAlignment="Center"
                                         KeyDown="BarcodeBox_KeyDown"
                                         TextChanged="BarcodeBox_TextChanged" 
                                         Foreground="White"
                                         CaretBrush="White"/>

                                <TextBlock Grid.Column="2"
                                           Text="Enter"
                                           VerticalAlignment="Center"
                                           Margin="10,0,0,0"
                                           Opacity="0.5"
                                           FontSize="11"
                                           />
                            </Grid>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                        <TextBlock Text="العميل الحالي" Style="{StaticResource SalesSectionTitleStyle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Height="42"
                                    CornerRadius="14"
                                    Background="{StaticResource Bg}"
                                    BorderBrush="{StaticResource BorderBrushDark}"
                                    BorderThickness="1"
                                    Padding="12,0">
                                <TextBlock x:Name="SelectedCustomerSummaryText"
                                           Text="Customer: Walk-in"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                            </Border>

                            
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,10,0">
                        <TextBlock Text="خصم الفاتورة" Style="{StaticResource SalesSectionTitleStyle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="InvoiceDiscountBox"
                                     Grid.Column="0"
                                     Height="42"
                                     Style="{StaticResource DarkTextBoxStyle}"
                                     Language="en-US"
                                     TextChanged="InvoiceDiscountBox_TextChanged"/>

                            <Border Grid.Column="1"
                                    Margin="8,0,0,0"
                                    Background="{StaticResource Bg}"
                                    BorderBrush="{StaticResource BorderBrushDark}"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="10,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <RadioButton x:Name="InvoiceDiscPercent"
                                                 Content="%"
                                                 IsChecked="True"
                                                 Margin="0,0,8,0"
                                                 Checked="InvoiceDiscountOption_Checked"/>
                                    <RadioButton x:Name="InvoiceDiscAmount"
                                                 Content="EGP"
                                                 Checked="InvoiceDiscountOption_Checked"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="3">
                        <TextBlock Text="مزايا العميل" Style="{StaticResource SalesSectionTitleStyle}"/>
                        <Border Height="42"
                                CornerRadius="14"
                                Background="{StaticResource Bg}"
                                BorderBrush="{StaticResource BorderBrushDark}"
                                BorderThickness="1"
                                Padding="12,0">
                            <TextBlock x:Name="CustomerDiscText"
                                       Text="Customer Discount: 0.00"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </Border>

                        <CheckBox x:Name="UsePointsCheckBox"
                                  Content="استخدام نقاط الولاء"
                                  Margin="0,8,0,0"
                                  Checked="UsePointsCheckBox_Checked"
                                  Unchecked="UsePointsCheckBox_Checked"/>

                        <TextBlock x:Name="RedeemPointsText"
                                   Opacity="0.75"
                                   Text="Redeemed Points: 0 | Discount: 0.00"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Cart -->
        <Border Grid.Row="3" Style="{StaticResource CardBorderStyle}" Padding="14" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="عناصر الفاتورة" FontSize="21" FontWeight="Bold"/>
                        <TextBlock Text="أضف بالباركود أو بالبحث، ثم عدّل الكمية والخصم من نفس الجدول"
                                   Opacity="0.7"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="{StaticResource Bg}"
                            BorderBrush="{StaticResource BorderBrushDark}"
                            BorderThickness="1"
                            CornerRadius="999"
                            Padding="12,6"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding ElementName=CartList, Path=Items.Count, StringFormat=عدد الأصناف: {0}}"
                                   FontWeight="SemiBold"
                                   Opacity="0.85"/>
                    </Border>
                </Grid>

                <ListView Grid.Row="1"
                          x:Name="CartList"
                          Style="{StaticResource DarkListViewStyle}"
                          ItemContainerStyle="{StaticResource DarkGridViewItemStyle}"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="الباركود" DisplayMemberBinding="{Binding Barcode}" Width="135"/>
                            <GridViewColumn Header="الصنف" DisplayMemberBinding="{Binding Name}" Width="220"/>
                            <GridViewColumn Header="المقاس" DisplayMemberBinding="{Binding Size}" Width="82"/>
                            <GridViewColumn Header="اللون" DisplayMemberBinding="{Binding Color}" Width="95"/>

                            <GridViewColumn Header="الكمية" Width="132">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource Bg}"
                            BorderBrush="{StaticResource BorderBrushDark}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="4"
                            HorizontalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="−"
                                    Width="28"
                                    Height="28"
                                    Style="{StaticResource DarkButtonStyle}"
                                    Click="QtyMinus_Click"/>
                                                <TextBlock Text="{Binding Qty}"
                                       Width="34"
                                       TextAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"/>
                                                <Button Content="+"
                                    Width="28"
                                    Height="28"
                                    Style="{StaticResource DarkButtonStyle}"
                                    Click="QtyPlus_Click"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Header="سعر الوحدة" DisplayMemberBinding="{Binding Price}" Width="96"/>

                            <GridViewColumn Header="الخصم" Width="150">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBox Width="65"
                                 Height="34"
                                 Style="{StaticResource DarkTextBoxStyle}"
                                 Language="en-US"
                                 Text="{Binding DiscountValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.##}}"
                                 TextChanged="LineDiscountValue_TextChanged"/>

                                            <ComboBox Width="58"
                                  Height="28"
                                  Margin="8,0,0,0"
                                  SelectionChanged="LineDiscountType_SelectionChanged"
                                  Style="{StaticResource DiscountComboStyle}"
                                  Loaded="LineDiscountTypeCombo_Loaded">
                                                <ComboBoxItem Content="%" Tag="Percent"/>
                                                <ComboBoxItem Content="EGP" Tag="Amount"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Header="الإجمالي" DisplayMemberBinding="{Binding LineTotalAfterDiscount}" Width="108"/>

                            <GridViewColumn Header="" Width="52">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Width="28"
                            Height="28"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="RemoveItem_Click"
                            ToolTip="حذف الصف">
                                            <Viewbox Width="18" Height="18">
                                                <Grid>
                                                    <Ellipse Stroke="#FB7185"
                                         StrokeThickness="1.8"
                                         Fill="Transparent"/>
                                                    <Rectangle Width="8"
                                           Height="1.8"
                                           Fill="#FB7185"
                                           RadiusX="1"
                                           RadiusY="1"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                                </Grid>
                                            </Viewbox>
                                        </Button>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="4" Style="{StaticResource CardBorderStyle}" Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.5*"/>
                    <ColumnDefinition Width="1.15*"/>
                </Grid.ColumnDefinitions>

                <WrapPanel Grid.Column="0" VerticalAlignment="Center" ItemHeight="46">
                    <Button MinWidth="130" Height="46" Margin="4,4,12,4" Content="دفع كاش  F12"
                            Style="{StaticResource PrimaryButtonStyle}" Click="PayCash_Click"/>
                    <Button MinWidth="120" Height="46" Margin="4,4,12,4" Content="فيزا"
                            Style="{StaticResource DarkButtonStyle}" Click="PayVisa_Click"/>
                    <Button MinWidth="120" Height="46" Margin="4,4,12,4" Content="تحويل"
                            Style="{StaticResource DarkButtonStyle}" Click="PayTransfer_Click"/>
                    <Button MinWidth="120" Height="46" Margin="4,4,12,4" Content="دفع متعدد"
                            Style="{StaticResource DarkButtonStyle}" Click="PaySplit_Click"/>
                    <Button MinWidth="120" Height="46" Margin="4,4,12,4" Content="طباعة"
                            Style="{StaticResource DarkButtonStyle}" Click="PrintReceipt_Click"/>
                    <Button MinWidth="120" Height="46" Margin="4,4,12,4" Content="تفريغ"
                            Style="{StaticResource DarkButtonStyle}" Click="Clear_Click"/>
                </WrapPanel>

                <Border Grid.Column="1"
                        Background="{StaticResource Bg}"
                        BorderBrush="{StaticResource BorderBrushDark}"
                        BorderThickness="1"
                        CornerRadius="18"
                        Padding="16"
                        Margin="12,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="عدد الأصناف" Opacity="0.78"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding ElementName=CartList, Path=Items.Count}"
                                   Opacity="0.78"/>

                        <TextBlock Grid.Row="1" Text="الإجمالي قبل الخصم" Opacity="0.85" Margin="0,8,0,0"/>
                        <TextBlock x:Name="SubTotalText" Grid.Row="1" Grid.Column="1" Text="0.00" Opacity="0.85" Margin="0,8,0,0"/>

                        <TextBlock Grid.Row="2" Text="إجمالي الخصومات" Opacity="0.75" Margin="0,8,0,0"/>
                        <TextBlock x:Name="InvoiceDiscountText" Grid.Row="2" Grid.Column="1" Text="0.00" Opacity="0.75" Margin="0,8,0,0"/>

                        <Border Grid.Row="3" Grid.ColumnSpan="2"
                                Margin="0,14,0,0"
                                Background="#1A2336"
                                BorderBrush="{StaticResource BorderBrushDark}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="12,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="الإجمالي النهائي" FontSize="22" FontWeight="Bold"/>
                                <TextBlock x:Name="TotalText" Grid.Column="1" Text="0.00" FontSize="24" FontWeight="Bold"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- PAYMENT OVERLAY -->
        <Grid x:Name="PaymentOverlay"
              Visibility="Collapsed"
              Grid.RowSpan="5"
              Background="#99000000">
            <Border Width="520"
                    Padding="18"
                    CornerRadius="18"
                    BorderBrush="{StaticResource BorderBrushDark}"
                    BorderThickness="1"
                    Background="{StaticResource Surface}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.35"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock x:Name="PayTitle" Text="الدفع" FontSize="21" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock Text="الإجمالي" Opacity="0.8"/>
                    <TextBlock x:Name="PayTotalText" Text="0.00" FontSize="28" FontWeight="Bold" Margin="0,0,0,14"/>

                    <TextBlock Text="المبلغ المستلم" Opacity="0.8"/>
                    <TextBox x:Name="ReceivedBox"
                             Height="40"
                             FontSize="16"
                             Style="{StaticResource DarkTextBoxStyle}"
                             Language="en-US"
                             Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="الباقي / المتبقي" Opacity="0.8"/>
                        <TextBlock x:Name="ChangeText" Grid.Column="1" Text="0.00" FontWeight="SemiBold"/>
                    </Grid>

                    <UniformGrid Columns="2">
                        <Button Height="44"
                                Margin="4"
                                Content="تأكيد"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="ConfirmPayment_Click"/>
                        <Button Height="44"
                                Margin="4"
                                Content="إلغاء"
                                Style="{StaticResource DarkButtonStyle}"
                                Click="CancelPayment_Click"/>
                    </UniformGrid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- CUSTOMER OVERLAY -->
        <Grid x:Name="CustomerOverlay"
              Visibility="Collapsed"
              Grid.RowSpan="5"
              Background="#99000000">

            <Border Width="920"
                    MaxWidth="1000"
                    Height="620"
                    Padding="18"
                    CornerRadius="18"
                    BorderBrush="{StaticResource BorderBrushDark}"
                    BorderThickness="1"
                    Background="{StaticResource Surface}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.35"/>
                </Border.Effect>

                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                        <TextBlock Text="اختيار عميل"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="CustomerSearchBox"
                                     Grid.Column="0"
                                     Style="{StaticResource DarkTextBoxStyle}"
                                     Height="40"
                                     VerticalContentAlignment="Center"
                                     TextChanged="CustomerSearchBox_TextChanged"/>

                            <Button Grid.Column="1"
                                    Margin="10,0,0,0"
                                    Width="42"
                                    Height="40"
                                    Content="+"
                                    FontSize="18"
                                    FontWeight="Bold"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="OpenAddCustomerOverlay_Click"/>
                        </Grid>

                        <TextBlock Text="ملاحظة: دبل كليك لاختيار العميل"
                                   Opacity="0.7"
                                   Margin="0,8,0,0"/>
                    </StackPanel>

                    <ListView x:Name="CustomersList"
                              Style="{StaticResource DarkListViewStyle}"
                              ItemContainerStyle="{StaticResource DarkGridViewItemStyle}"
                              MouseDoubleClick="CustomersList_MouseDoubleClick"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Id" DisplayMemberBinding="{Binding Id}" Width="70"/>
                                <GridViewColumn Header="الاسم" DisplayMemberBinding="{Binding Name}" Width="240"/>
                                <GridViewColumn Header="الموبايل" DisplayMemberBinding="{Binding Phone}" Width="180"/>
                                <GridViewColumn Header="النقاط" DisplayMemberBinding="{Binding LoyaltyPoints}" Width="100"/>
                                <GridViewColumn Header="نوع الخصم" DisplayMemberBinding="{Binding SpecialDiscountType}" Width="110"/>
                                <GridViewColumn Header="قيمة الخصم" DisplayMemberBinding="{Binding SpecialDiscountValue}" Width="100"/>
                                <GridViewColumn Header="نشط" DisplayMemberBinding="{Binding IsActive}" Width="80"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <UniformGrid DockPanel.Dock="Bottom" Columns="2" Margin="0,12,0,0">
                        <Button Height="44"
                                Margin="4"
                                Content="اختيار"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="CustomerSelect_Click"/>
                        <Button Height="44"
                                Margin="4"
                                Content="إلغاء"
                                Style="{StaticResource DarkButtonStyle}"
                                Click="CustomerOverlayCancel_Click"/>
                    </UniformGrid>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ADD CUSTOMER OVERLAY -->
        <Grid x:Name="AddCustomerOverlay"
              Visibility="Collapsed"
              Grid.RowSpan="5"
              Background="#99000000">

            <Border Width="460"
                    Padding="16"
                    CornerRadius="18"
                    BorderBrush="{StaticResource BorderBrushDark}"
                    BorderThickness="1"
                    Background="{StaticResource Surface}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.35"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="إضافة عميل"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,14"/>

                    <TextBlock Grid.Row="1"
                               Text="الاسم"
                               Margin="0,0,0,6"
                               Opacity="0.85"/>

                    <TextBox x:Name="NewCustomerNameBox"
                             Grid.Row="2"
                             Height="38"
                             Style="{StaticResource DarkTextBoxStyle}"/>

                    <TextBlock Grid.Row="3"
                               Text="الموبايل"
                               Margin="0,12,0,6"
                               Opacity="0.85"/>

                    <TextBox x:Name="NewCustomerPhoneBox"
                             Grid.Row="4"
                             Height="38"
                             Style="{StaticResource DarkTextBoxStyle}"/>

