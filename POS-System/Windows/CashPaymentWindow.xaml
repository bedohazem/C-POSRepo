<Window x:Class="POS_System.CashPaymentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cash Payment" Height="260" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Total:" FontSize="16" VerticalAlignment="Center"/>
        <TextBlock x:Name="TotalText" Grid.Column="1" FontSize="16" FontWeight="Bold"
                   VerticalAlignment="Center"/>

        <TextBlock Grid.Row="1" Text="Received:" FontSize="16" VerticalAlignment="Center" Margin="0,12,0,0"/>
        <TextBox x:Name="ReceivedBox" Grid.Row="1" Grid.Column="1"
                 Height="36" Margin="0,12,0,0"
                 FontSize="16" Padding="10,6"
                 TextChanged="ReceivedBox_TextChanged"/>

        <TextBlock Grid.Row="2" Text="Remains:" FontSize="16" VerticalAlignment="Center" Margin="0,12,0,0"/>
        <TextBlock x:Name="ChangeText" Grid.Row="2" Grid.Column="1"
                   FontSize="16" FontWeight="Bold" Margin="0,12,0,0"
                   VerticalAlignment="Center"/>

        <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
        <Button x:Name="ConfirmBtn" Content="Confirm"
                    IsEnabled="False" Click="Confirm_Click" Grid.ColumnSpan="2" Margin="57,56,211,17" Grid.Row="3"/>
        <Button Content="Cancel" Margin="93,58,55,15"
                    Click="Cancel_Click" Grid.Column="1" Grid.Row="3"/>
    </Grid>
</Window>
